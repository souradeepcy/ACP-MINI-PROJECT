#include <stdio.h>
#include <stdlib.h>
#include <math.h>

#define WIDTH 60
#define HEIGHT 30
#define PI 3.1415926535

// Visual stretch correction: characters are typically taller than they are wide
#define X_SCALE 2.0 

char canvas[HEIGHT][WIDTH];

// Function Prototypes
void initCanvas();
void displayCanvas();
void drawLine(int x1, int y1, int x2, int y2, char ch);
void drawRect(int x1, int y1, int x2, int y2, char ch);
void drawCircle(int cx, int cy, int r, char ch);
void drawTriangle(int x1, int y1, int x2, int y2, int x3, int y3, char ch);
void deleteObject();

int main() {
    int choice;
    initCanvas();

    while (1) {
        printf("\n--- 2D Graphics Editor ---\n");
        printf("1. Draw Line\n");
        printf("2. Draw Rectangle\n");
        printf("3. Draw Circle\n");
        printf("4. Draw Triangle\n");
        printf("5. Erase / Delete an Object Area\n");
        printf("6. Display Canvas\n");
        printf("7. Clear Canvas\n");
        printf("8. Exit\n");
        printf("Enter your choice: ");
        if (scanf("%d", &choice) != 1) {
            printf("Invalid input. Exiting.\n");
            break;
        }

        if (choice == 8) {
            printf("Exiting program. Goodbye!\n");
            break;
        }

        switch (choice) {
            case 1: {
                int x1, y1, x2, y2;
                printf("Enter Start Coordinates (x1 y1) [0-%d 0-%d]: ", WIDTH-1, HEIGHT-1);
                scanf("%d %d", &x1, &y1);
                printf("Enter End Coordinates (x2 y2): ");
                scanf("%d %d", &x2, &y2);
                drawLine(x1, y1, x2, y2, '*');
                displayCanvas();
                break;
            }
            case 2: {
                int x1, y1, x2, y2;
                printf("Enter Top-Left corner (x1 y1): ");
                scanf("%d %d", &x1, &y1);
                printf("Enter Bottom-Right corner (x2 y2): ");
                scanf("%d %d", &x2, &y2);
                drawRect(x1, y1, x2, y2, '*');
                displayCanvas();
                break;
            }
            case 3: {
                int cx, cy, r;
                printf("Enter Center coordinates (cx cy): ");
                scanf("%d %d", &cx, &cy);
                printf("Enter Radius: ");
                scanf("%d", &r);
                drawCircle(cx, cy, r, '*');
                displayCanvas();
                break;
            }
            case 4: {
                int x1, y1, x2, y2, x3, y3;
                printf("Enter Vertex 1 (x1 y1): ");
                scanf("%d %d", &x1, &y1);
                printf("Enter Vertex 2 (x2 y2): ");
                scanf("%d %d", &x2, &y2);
                printf("Enter Vertex 3 (x3 y3): ");
                scanf("%d %d", &x3, &y3);
                drawTriangle(x1, y1, x2, y2, x3, y3, '*');
                displayCanvas();
                break;
            }
            case 5:
                deleteObject();
                displayCanvas();
                break;
            case 6:
                displayCanvas();
                break;
            case 7:
                initCanvas();
                printf("Canvas cleared.\n");
                break;
            default:
                printf("Invalid choice! Please select a valid option.\n");
        }
    }
    return 0;
}

// Initializes the canvas with the background character '_'
void initCanvas() {
    for (int i = 0; i < HEIGHT; i++) {
        for (int j = 0; j < WIDTH; j++) {
            canvas[i][j] = '_';
        }
    }
}

// Outputs the 2D grid to the console
void displayCanvas() {
    printf("\n--- CURRENT CANVAS ---\n");
    for (int i = 0; i < HEIGHT; i++) {
        for (int j = 0; j < WIDTH; j++) {
            putchar(canvas[i][j]);
        }
        putchar('\n');
    }
}

// Safe plot function to ensure we don't write out of bounds
void plot(int x, int y, char ch) {
    if (x >= 0 && x < WIDTH && y >= 0 && y < HEIGHT) {
        canvas[y][x] = ch;
    }
}

// Bresenham's Line Generation Algorithm
void drawLine(int x1, int y1, int x2, int y2, char ch) {
    int dx = abs(x2 - x1);
    int dy = abs(y2 - y1);
    int sx = (x1 < x2) ? 1 : -1;
    int sy = (y1 < y2) ? 1 : -1;
    int err = dx - dy;

    while (1) {
        plot(x1, y1, ch);
        if (x1 == x2 && y1 == y2) break;
        int e2 = 2 * err;
        if (e2 > -dy) {
            err -= dy;
            x1 += sx;
        }
        if (e2 < dx) {
            err += dx;
            y1 += sy;
        }
    }
}

// Draws a rectangle using 4 lines
void drawRect(int x1, int y1, int x2, int y2, char ch) {
    drawLine(x1, y1, x2, y1, ch); // Top
    drawLine(x1, y2, x2, y2, ch); // Bottom
    drawLine(x1, y1, x1, y2, ch); // Left
    drawLine(x2, y1, x2, y2, ch); // Right
}

// Draws a circle accounting for non-square terminal text cells
void drawCircle(int cx, int cy, int r, char ch) {
    // We scan the bounding box of the circle
    for (int y = cy - r; y <= cy + r; y++) {
        for (int x = cx - (int)(r * X_SCALE); x <= cx + (int)(r * X_SCALE); x++) {
            // Apply scale inverse to X distance calculation
            double dx = (x - cx) / X_SCALE;
            double dy = y - cy;
            double distance = sqrt(dx * dx + dy * dy);
            
            // If the point is close to the perimeter edge, plot it
            if (fabs(distance - r) < 0.5) {
                plot(x, y, ch);
            }
        }
    }
}

// Draws a triangle by connecting its 3 vertices
void drawTriangle(int x1, int y1, int x2, int y2, int x3, int y3, char ch) {
    drawLine(x1, y1, x2, y2, ch);
    drawLine(x2, y2, x3, y3, ch);
    drawLine(x3, y3, x1, y1, ch);
}

// Deletes objects by filling a user-defined bounding box back with '_'
void deleteObject() {
    int x1, y1, x2, y2;
    printf("\n--- Delete / Erase Tool ---\n");
    printf("Enter Top-Left corner to erase (x1 y1): ");
    scanf("%d %d", &x1, &y1);
    printf("Enter Bottom-Right corner to erase (x2 y2): ");
    scanf("%d %d", &x2, &y2);

    for (int y = y1; y <= y2; y++) {
        for (int x = x1; x <= x2; x++) {
            plot(x, y, '_');
        }
    }
    printf("Area erased.\n");
}

