            drawLineNC(x1, y1, x2, y1, '*');
            drawLineNC(x1, y2, x2, y2, '*');
            drawLineNC(x1, y1, x1, y2, '*');
            drawLineNC(x2, y1, x2, y2, '*');
        }
        else if (choice == '3') {
            int cx, cy, r;
            printw("Circle (cx cy radius): ");
            scanw("%d %d %d", &cx, &cy, &r);
            drawCircleNC(cx, cy, r, '*');
        }
        else if (choice == '4') {
            int x1, y1, x2, y2, x3, y3;
            printw("Triangle (x1 y1 x2 y2 x3 y3): ");
            scanw("%d %d %d %d %d %d", &x1, &y1, &x2, &y2, &x3, &y3);
            drawLineNC(x1, y1, x2, y2, '*');
            drawLineNC(x2, y2, x3, y3, '*');
            drawLineNC(x3, y3, x1, y1, '*');
        }
        else if (choice == '5') {
            int x1, y1, x2, y2;
            printw("Erase Area (x1 y1 x2 y2): ");
