    while(1) {
        // Render control text at the base screen buffer
        mvprintw(max_y - 3, 0, "1: Line | 2: Rect | 3: Circle | 4: Triangle | 5: Erase Box | 6: Clear | 7: Exit");
        refresh();
        
        choice = getch();
