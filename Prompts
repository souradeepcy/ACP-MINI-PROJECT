#include <ncurses.h>
#include <stdlib.h>
#include <math.h>

#define X_SCALE 2.0

void initCanvas(int h, int w) {
    for (int y = 0; y < h; y++) {
        for (int x = 0; x < w; x++) {
            mvaddch(y, x, '_');
        }
    }
}

void drawLineNC(int x1, int y1, int x2, int y2, char ch) {
    int dx = abs(x2 - x1);
    int dy = abs(y2 - y1);
    int sx = (x1 < x2) ? 1 : -1;
    int sy = (y1 < y2) ? 1 : -1;
    int err = dx - dy;

    while (1) {
        mvaddch(y1, x1, ch);
        if (x1 == x2 && y1 == y2) break;
        int e2 = 2 * err;
        if (e2 > -dy) { err -= dy; x1 += sx; }
        if (e2 < dx) { err += dx; y1 += sy; }
    }
}

void drawCircleNC(int cx, int cy, int r, char ch) {
    for (int y = cy - r; y <= cy + r; y++) {
        for (int x = cx - (int)(r * X_SCALE); x <= cx + (int)(r * X_SCALE); x++) {
            double dx = (x - cx) / X_SCALE;
            double dy = y - cy;
            if (fabs(sqrt(dx*dx + dy*dy) - r) < 0.5) {
                mvaddch(y, x, ch);
            }
        }
    }
}

int main() {
    initscr();             // Start ncurses mode
    cbreak();              // Line buffering disabled
    noecho();              // Don't echo keys pressed
    keypad(stdscr, TRUE);  // Enable arrow keys

    int max_y, max_x;
